{
  "name": "ViraSEO — Health Check",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "viraseo-health",
        "responseMode": "lastNode"
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [200, 300]
    },
    {
      "parameters": {
        "jsCode": "return [{json: {status: 'ok', timestamp: new Date().toISOString(), version: '3.0', message: 'ViraSEO n8n connection is working!'}}];"
      },
      "name": "Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [400, 300]
    }
  ],
  "connections": {
    "Webhook": {"main": [[{"node": "Response", "type": "main", "index": 0}]]}
  },
  "settings": {"executionTimeout": 10},
  "tags": [{"name": "ViraSEO"}]
}
